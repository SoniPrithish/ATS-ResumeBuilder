# ============================================================
# TechResume AI — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Database (Neon.tech PostgreSQL) ──────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/techresume?sslmode=require
DIRECT_URL=postgresql://user:password@host:5432/techresume?sslmode=require

# ── NextAuth (Auth.js v5) ────────────────────────────────────
AUTH_SECRET=your-auth-secret-generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# GitHub OAuth
AUTH_GITHUB_ID=your-github-client-id
AUTH_GITHUB_SECRET=your-github-client-secret

# Google OAuth
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# ── Upstash Redis ───────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ── Upstash QStash ──────────────────────────────────────────
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=your-qstash-signing-key
QSTASH_NEXT_SIGNING_KEY=your-qstash-next-signing-key

# ── Cloudflare R2 (S3-compatible) ────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=techresume-uploads
R2_PUBLIC_URL=https://your-r2-public-url.r2.dev

# ── Google AI (Gemini) ──────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-api-key
